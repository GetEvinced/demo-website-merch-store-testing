{
  "name": "demo-website",
  "version": "1.0.0",
  "description": "A React demo website",
  "main": "src/index.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config tests/e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report tests/e2e/playwright-report"
  },
  "dependencies": {
    "@evinced/js-playwright-sdk": "^2.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "@playwright/test": "^1.44.1",
    "@types/node": "^20.14.5",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.4",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
